{
  "window.autoDetectColorScheme": true,
  "workbench.preferredLightColorTheme": "Cursor Dark",
  "workbench.iconTheme": "material-icon-theme",
  "go.alternateTools": {
    "go": "~/.local/share/mise/installs/go/latest/go/bin/go",
  },
  "explorer.compactFolders": false,
  "editor.tabSize": 2,
  "editor.fontFamily": "JetBrainsMono Nerd Font",
  "editor.fontSize": 14,
  "editor.lineHeight": 1.3,
  "terminal.integrated.fontSize": 14,
  "editor.rulers": [80, 120, 160],
  "editor.fontLigatures": true,
  "[jsonc]": {
    "editor.defaultFormatter": "esbenp.prettier-vscode",
  },
  "editor.formatOnSave": true,
  "terminal.integrated.cursorStyle": "line",
  "terminal.integrated.cursorStyleInactive": "line",
  "files.exclude": {
    "**/CVS": true,
    "**/.DS_Store": true,
    "**/.hg": true,
    "**/.svn": true,
    "node_modules": true,
  },
  "workbench.startupEditor": "newUntitledFile",
  "editor.multiCursorLimit": 50000,
  "rubyLsp.indexing": {
    "excludedPatterns": ["**/test/**/*.rb"],
    "includedPatterns": ["**/bin/**/*"],
    "excludedGems": ["rubocop", "rubocop-performance"],
    "excludedMagicComments": ["compiled:true"],
  },
  "go.testFlags": ["-count=1"],
}
